# Application
PROJECT_NAME="SafeX Customer Support Chatbot"
DEBUG=True
API_V1_STR="/api/v1"

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=safex_chatbot
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM & Embeddings
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=phi3:mini
EMBEDDING_MODEL=all-MiniLM-L6-v2
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Security & Webhooks
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
N8N_WEBHOOK_SECRET=CHANGE_THIS_TO_MATCH_N8N_WEBHOOK_SECRET
WHATSAPP_CLOUD_API_SECRET=CHANGE_THIS_TO_META_APP_SECRET
WHATSAPP_VERIFY_TOKEN=CHANGE_THIS_TO_META_VERIFY_TOKEN

# n8n
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
TIMEZONE=UTC
